{
  "name": "abi-car-rental",
  "version": "1.0.0",
  "description": "ABI Car & Van Rental",
  "main": "dist/server/index.js",
  "scripts": {
  "build": "tsc && bash scripts/copy-client.sh",
  "start": "node dist/server/index.js",
